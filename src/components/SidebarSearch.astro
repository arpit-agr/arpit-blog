---
const path = Astro.url.pathname;
const isArchivePage = path.endsWith('/archive/');
const isTagsPage = path.endsWith('/tags/');
---

<section id="search">
	<div class="center p-space-m">
		<div class="stack align-self-stretch">
			<h2 class="heading-3" id="search_heading">Search</h2>
			<search class="align-self-stretch">
				<form
					id="sidebar-search-form"
					class="stack"
					action="https://duckduckgo.com/"
					method="get"
				>
					<label
						class="heading-3 text-box-trim visually-hidden"
						for="search-term"
					>
						Search
					</label>
					<div class="align-self-stretch">
						<div>
							<input
								class="text-box-trim"
								type="search"
								id="search-term"
								name="q"
							/>
							<input class="sidebar" hidden name="sites" value="arpit.blog" />
						</div>
						<button
							class="sidebar text-box-trim align-self-stretch"
							type="submit"
						>
							Go!
						</button>
					</div>
				</form>
			</search>
			<ul class="multi-col align-self-stretch">
				{
					!isArchivePage && (
						<li>
							Or <a href="/archive/">browse the archive</a>
						</li>
					)
				}
				{
					!isTagsPage && (
						<li>
							Or <a href="/tags/">browse the tags</a>
						</li>
					)
				}
			</ul>
		</div>
	</div>
</section>

<script>
	const form = document.getElementById(
		'sidebar-search-form',
	) as HTMLFormElement | null;
	form?.addEventListener('submit', (event) => {
		event.preventDefault();
		const input = form.querySelector<HTMLInputElement>('input[name="q"]');
		const query = input?.value.trim() ?? '';
		const url = query ? `/search/?q=${encodeURIComponent(query)}` : '/search/';
		window.location.assign(url);
	});
</script>
