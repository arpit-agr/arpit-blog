---
interface Props {
	sectionTitle: string;
	sectionDesc?: string;
}

const { sectionTitle, sectionDesc } = Astro.props;
---

<div class="feed-header">
	<div class="center pi-space-m">
		{
			!!sectionTitle && !!sectionDesc ? (
				<hgroup class="align-self-stretch">
					<h1 class="text-box-trim">{sectionTitle}</h1>
					<p class="text-box-trim text-balance">{sectionDesc}</p>
				</hgroup>
			) : !!sectionTitle ? (
				<h1 class="align-self-stretch">{sectionTitle}</h1>
			) : (
				<p class="align-self-stretch">{sectionDesc}</p>
			)
		}
	</div>
</div>
