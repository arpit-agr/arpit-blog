---
import type { GetStaticPaths } from 'astro';
import FeedPage from '@layouts/FeedPage.astro';
import { loadAndFormatCollection } from '@utils/collection';
import { LINKS_TITLE, LINKS_DESCRIPTION } from 'src/consts';

export const getStaticPaths = (async ({ paginate }) => {
	const allEntries = await loadAndFormatCollection('links');
	return paginate(allEntries, { pageSize: 20 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<FeedPage
	page={page}
	title={LINKS_TITLE}
	description={LINKS_DESCRIPTION}
	sectionTitle="Links"
/>
